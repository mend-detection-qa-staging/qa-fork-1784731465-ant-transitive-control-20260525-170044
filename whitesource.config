# Unified Agent configuration for Ant+Ivy resolution.
# Without these flags the UA Ant resolver falls back to Mode 3
# (binary file path scan) and emits zero deps for a manifest-only probe.
# Mode 1 (Ivy resolution via ivy.xml + ivysettings.xml) only fires when
# both flags below are true. See whitesource/unified-agent
# .claude/knowledge/resolvers/java-jvm.md  3 Ant Resolver.
#
# ASPIRATIONAL: As of the bolt-4 SCM scanner, ant.ivyResolveDependencies=true
# is NOT honored by the SCM integration path. This config is present for
# pipeline-mode `mend ua` testing. Mode-3 path scan (lib/*.jar fingerprinting)
# is the expected scanner behavior for SCM integration.

ant.resolveDependencies=true
ant.ivyResolveDependencies=true

# Resolve both compile and runtime configurations.
# Empty list means no configurations are ignored.
ant.ivyIgnoredConfigurations=

# Do not exclude source files from fingerprinting.
# The probe ships no Java sources so this is a no-op but keeps behavior explicit.
ant.ignoreSourceFiles=false
